index 0000000..5c8eb8c
--- /dev/null
+++ b/build_pyg_for_torch29.sh
@@ -0,0 +1,87 @@
+#!/usr/bin/env bash
+# Source-build torch_scatter / torch_cluster / torch_sparse for torch 2.9 + cu128 in
+# the active conda env. Required because Rocky 8.10's glibc 2.28 is older than the
+# 2.32 the data.pyg.org pre-built linux_x86_64 wheels require. Building from source
+# links the .so files against the host's glibc instead.
+#
+# Run on an H200 (pg_tata) compute node — login007 has no nvcc. Allocate via:
+#   srun -p pg_tata --gres=gpu:1 --time=01:00:00 --mem=32G --cpus-per-task=8 --pty bash
+#   conda activate llm
+#   cd /home/sathyae/mclm/external/mattergen
+#   bash build_pyg_for_torch29.sh
+#
+# Compile time: ~10-25 min total (8 cores). pyg_lib stays as the manylinux_2_28 wheel
+# already installed (works fine on glibc 2.28).
+#
+# Idempotent: re-running will rebuild and reinstall in place.
+
+set -euo pipefail
+
+if [[ -z "${CONDA_PREFIX:-}${VIRTUAL_ENV:-}" ]]; then
+  echo "ERROR: activate the conda env first (e.g. \`conda activate llm\`)."
+  exit 1
+fi
+
+# Sanity: torch must be importable and CUDA must be available.
+python -c "
+import torch
+assert torch.cuda.is_available(), 'torch.cuda.is_available() is False — are you on a GPU node?'
+print(f'torch {torch.__version__}, cuda {torch.version.cuda}, device {torch.cuda.get_device_name(0)}')
+"
+
+# Sanity: nvcc must be on PATH and match torch's CUDA major.
+if ! command -v nvcc >/dev/null 2>&1; then
+  echo "ERROR: nvcc not on PATH. Try: module load cuda/12.8"
+  exit 1
+fi
+NVCC_VER=$(nvcc --version | grep -oE 'release [0-9]+\.[0-9]+' | awk '{print $2}')
+echo "nvcc release: ${NVCC_VER}"
+
+# H200 / H100 are sm_90. (Stage 3a is on H200.)
+export TORCH_CUDA_ARCH_LIST="9.0"
+export FORCE_CUDA=1
+export MAX_JOBS=${MAX_JOBS:-8}
+
+# Set CUDA_HOME if not already (some build scripts use it directly).
+export CUDA_HOME="${CUDA_HOME:-$(dirname "$(dirname "$(command -v nvcc)")")}"
+echo "CUDA_HOME: ${CUDA_HOME}"
+echo "TORCH_CUDA_ARCH_LIST: ${TORCH_CUDA_ARCH_LIST}"
+
+# Remove any pre-built versions first so pip is forced to recompile.
+pip uninstall -y torch_scatter torch_cluster torch_sparse 2>/dev/null || true
+
+# `-v` makes pip stream the build subprocess output (nvcc lines, gcc lines, etc.)
+# instead of showing one spinner line per package — important when builds take
+# 5-15 min each. Also tee everything to a log so you can inspect later.
+LOG_DIR="${HOME}/mclm_pyg_build_logs"
+mkdir -p "$LOG_DIR"
+
+echo "[1/3] Building torch_scatter 2.1.2 from source (logs → $LOG_DIR/torch_scatter.log) ..."
+pip install -v --no-binary torch_scatter --no-cache-dir --no-build-isolation torch_scatter==2.1.2 \
+  2>&1 | tee "$LOG_DIR/torch_scatter.log"
+
+echo "[2/3] Building torch_cluster 1.6.3 from source (logs → $LOG_DIR/torch_cluster.log) ..."
+pip install -v --no-binary torch_cluster --no-cache-dir --no-build-isolation torch_cluster==1.6.3 \
+  2>&1 | tee "$LOG_DIR/torch_cluster.log"
+
+echo "[3/3] Building torch_sparse 0.6.18 from source (logs → $LOG_DIR/torch_sparse.log) ..."
+pip install -v --no-binary torch_sparse --no-cache-dir --no-build-isolation torch_sparse==0.6.18 \
+  2>&1 | tee "$LOG_DIR/torch_sparse.log"
+
+echo
+echo "Smoke-check (CUDA ops):"
+python -c "
+import torch, torch_scatter, torch_cluster, torch_sparse
+x = torch.randn(8, 16, device='cuda')
+idx = torch.tensor([0, 0, 1, 1, 2, 2, 3, 3], device='cuda')
+out = torch_scatter.scatter_add(x, idx, dim=0)
+print(f'  torch_scatter {torch_scatter.__version__} — scatter_add CUDA OK, out.shape={tuple(out.shape)}')
+print(f'  torch_cluster {torch_cluster.__version__}')
+print(f'  torch_sparse  {torch_sparse.__version__}')
+"
+
+echo
+echo "Done. mattergen import should now succeed:"
+echo "  python -c 'import mattergen, mattergen.adapter; print(\"OK\")'"
+echo
+echo "Reminder: Stage 3a runs need PYTHONPATH=/home/sathyae/mclm/alm so AtomsMapper resolves."
diff --git a/install_for_h200.sh b/install_for_h200.sh
new file mode 100755
index 0000000..bd4489b
--- /dev/null
+++ b/install_for_h200.sh
@@ -0,0 +1,112 @@
+#!/usr/bin/env bash
+# Install mattergen (this fork) into the active conda/venv env on an H200 box.
+#
+# Two supported scenarios — the script auto-detects which:
+#   (a) Fresh `mattergen` env (no torch installed yet): installs torch 2.5.1+cu124 +
+#       matching PyG companion wheels, then `pip install -e .`.
+#   (b) Co-install into mclm's `llm` env (torch 2.9.0+cu128 + flash-attn 2.8.3 already
+#       present): leaves torch alone, installs PyG companion wheels matching torch 2.9
+#       + cu128, then `pip install -e .`. This lets ALM (Qwen3 + LoRA + projector +
+#       OrbV3) and MatterGen run in one Python process — useful for real-time serving.
+#
+# pyproject.toml is loosened (torch>=2.5,<2.10; pytorch-lightning>=2.4,<2.6;
+# numpy>=1.26,<3; etc.) so the same install path works for both envs.
+#
+# Usage (a) — fresh env:
+#   conda create -n mattergen python=3.10 -y && conda activate mattergen
+#   cd /home/sathyae/mclm/external/mattergen && bash install_for_h200.sh
+#
+# Usage (b) — co-install into llm:
+#   conda activate llm
+#   cd /home/sathyae/mclm/external/mattergen && bash install_for_h200.sh
+
+set -euo pipefail
+
+if [[ -z "${CONDA_PREFIX:-}${VIRTUAL_ENV:-}" ]]; then
+  echo "ERROR: no conda or venv env detected. Activate one first."
+  exit 1
+fi
+
+PY=$(python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
+if [[ "$PY" != "3.10" ]]; then
+  echo "ERROR: Python 3.10 required (got $PY)."
+  exit 1
+fi
+
+# Detect existing torch.
+TORCH_VERSION=$(python -c "
+try:
+    import torch
+    print(torch.__version__)
+except ImportError:
+    print('')
+" 2>/dev/null)
+
+case "$TORCH_VERSION" in
+  "")
+    echo "[scenario A] no torch installed — installing 2.5.1+cu124."
+    pip install --index-url https://download.pytorch.org/whl/cu124 \
+      torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1
+    PYG_TORCH=2.5.0
+    PYG_CU=cu124
+    PYG_PT=pt25
+    PYG_LIB_VER=0.4.0
+    PYG_LIB_TAG="${PYG_PT}${PYG_CU}-cp310-cp310-linux_x86_64"
+    ;;
+  2.9.*)
+    echo "[scenario B-2.9] torch ${TORCH_VERSION} present."
+    echo "  pyg_lib has a manylinux_2_28 build (works on Rocky 8.10's glibc 2.28)."
+    echo "  torch_scatter/cluster/sparse pre-built linux_x86_64 wheels need glibc 2.32"
+    echo "  (verified: data.pyg.org wheels for torch-2.9.0+cu128 link against GLIBC_2.32)."
+    echo "  Installing pyg_lib only here — run build_pyg_for_torch29.sh on a GPU"
+    echo "  compute node to source-build the other three."
+    pip install \
+      "https://data.pyg.org/whl/torch-2.9.0+cu128/pyg_lib-0.6.0+pt29cu128-cp310-cp310-manylinux_2_28_x86_64.whl"
+    pip install -e .
+    echo
+    echo "Next step (on a pg_tata GPU node):"
+    echo "  srun -p pg_tata --gres=gpu:1 --time=01:00:00 --mem=32G --cpus-per-task=8 --pty bash"
+    echo "  conda activate llm  # or whichever env you ran this script in"
+    echo "  cd $(pwd) && bash build_pyg_for_torch29.sh"
+    exit 0
+    ;;
+  2.5.*|2.6.*|2.7.*|2.8.*)
+    MIN=$(echo "$TORCH_VERSION" | awk -F. '{print $1"."$2}')
+    NUM=$(echo "$MIN" | tr -d .)
+    echo "[scenario B'] torch ${TORCH_VERSION} present — assuming cu128 PyG wheels."
+    echo "             If your torch is +cu124 instead, edit PYG_CU below."
+    PYG_TORCH="${MIN}.0"
+    PYG_CU=cu128
+    PYG_PT="pt${NUM}"
+    PYG_LIB_VER=0.4.0
+    PYG_LIB_TAG="${PYG_PT}${PYG_CU}-cp310-cp310-linux_x86_64"
+    ;;
+  *)
+    echo "ERROR: torch ${TORCH_VERSION} not handled by this script. Supported: 2.5–2.9."
+    exit 1
+    ;;
+esac
+
+PYG_BASE="https://data.pyg.org/whl/torch-${PYG_TORCH}+${PYG_CU}"
+echo "[next] PyG companion wheels from ${PYG_BASE}"
+
+# pyg_lib has a different filename pattern (manylinux_2_28 for newer torch).
+# Use the precomputed PYG_LIB_TAG.
+pip install \
+  "${PYG_BASE}/pyg_lib-${PYG_LIB_VER}+${PYG_LIB_TAG}.whl" \
+  "${PYG_BASE}/torch_cluster-1.6.3+${PYG_PT}${PYG_CU}-cp310-cp310-linux_x86_64.whl" \
+  "${PYG_BASE}/torch_scatter-2.1.2+${PYG_PT}${PYG_CU}-cp310-cp310-linux_x86_64.whl" \
+  "${PYG_BASE}/torch_sparse-0.6.18+${PYG_PT}${PYG_CU}-cp310-cp310-linux_x86_64.whl"
+
+echo "[next] mattergen (this fork) + remaining deps ..."
+pip install -e .
+
+echo
+echo "Done. Smoke-check:"
+python -c "
+import torch, pytorch_lightning, mattergen, torch_scatter, torch_cluster, torch_sparse
+print('torch', torch.__version__, '| cuda', torch.version.cuda, '| pl', pytorch_lightning.__version__,
+      '| torch_scatter', torch_scatter.__version__)
+"
+echo
+echo "Reminder: Stage 3a runs need PYTHONPATH=/home/sathyae/mclm/alm so AtomsMapper resolves."
